    "challenge_monotonic_tolerance": 0.01,
    "single_failure_encounter_share_max": 0.5,
    "minimum_iterations_for_hard_gate": 128,
    "design_note": "挑战档整体均值严格使用目标区间；单角色允许 3% 样本容差，启发式 AI 的角色差距硬门槛为 9%，人工试玩继续以 5% 为目标。胜率必须和失败点分布一起看。"
  },
