    "minimum_card_comparison_runs": 20,
    "max_character_win_rate_gap": 0.05,
    "single_failure_encounter_share_max": 0.5,
    "max_abandon_rate": 0.35,
    "design_note": "每格 12 个完成样本只用于发现方向，至少 30 个完成样本才允许触发角色或挑战硬调参；单卡胜率比较要求至少 20 个获取或打出样本。放弃和进行中跑团单列，禁止混入胜率分母。"
  },
  "campaign_targets": {
    "_comment": "自动战役模拟目标。启发式 AI 不是人类水平，因此目标胜率低于真实玩家预期，用于观察相对平衡。",
